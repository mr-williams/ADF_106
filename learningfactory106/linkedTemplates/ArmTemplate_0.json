									"userProperties": [],
									"typeProperties": {
										"notebookPath": "/Users/oluwadamilare.williams@outlook.com/API-medallion Project/API to Landing zone",
										"baseParameters": {
											"section": "mileages",
											"year": {
												"value": "@string(item())",
												"type": "Expression"
											},
											"filename": {
												"value": "@concat('mileages_', string(item()))",
												"type": "Expression"
											}
										}
									},
									"linkedServiceName": {
										"referenceName": "API_car_project",
										"type": "LinkedServiceReference"
									}
								}
							]
						}
					}
				],
				"concurrency": 1,
				"policy": {
					"elapsedTimeMetric": {}
				},
				"variables": {
					"years": {
						"type": "Array",
						"defaultValue": [
