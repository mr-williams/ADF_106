							2016,
							2017,
							2018,
							2019
						]
					},
					"debug years": {
						"type": "Array"
					}
				},
				"annotations": [],
				"lastPublishTime": "2025-05-13T23:23:12Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/API_car_project')]"
			]
		},
